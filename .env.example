REGENT_ENVIRONMENT=development
REGENT_DATABASE_URL=postgresql+psycopg://regent:regent@localhost:5432/regent
REGENT_LOG_LEVEL=INFO
REGENT_WORKER_POLL_SECONDS=1.0
REGENT_WORKER_LEASE_SECONDS=30

# P1 generation and isolated build
REGENT_WORKSPACE_ROOT=/var/lib/regent/workspaces
REGENT_BUILD_ROOT=/var/lib/regent/builds
REGENT_SANDBOX_IMAGE=regent-python-web-v1-sandbox:1
REGENT_DEPENDENCY_RESOLVER_IMAGE=regent-python-web-v1-resolver:1
# Required for dependency materialization; leave unset to fail closed.
# REGENT_DEPENDENCY_EGRESS_PROXY=http://dependency-egress-proxy:3128

# Remote deploy (never commit real secrets; export these in the shell or a local .env)
# SERVER_IP=
# LOGIN_USER=
# LOGIN_PASSWORD=
